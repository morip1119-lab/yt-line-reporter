# ─────────────────────────────────────────────
# 共通設定
# ─────────────────────────────────────────────

# YouTube Data API v3 キー（Google Cloud Console で取得）
YOUTUBE_API_KEY=YOUR_YOUTUBE_API_KEY_HERE

# LINE Messaging API チャンネルアクセストークン（LINE Developers Console で取得）
LINE_CHANNEL_ACCESS_TOKEN=YOUR_LINE_CHANNEL_ACCESS_TOKEN_HERE

# レポート送信時刻（24時間表記 HH:MM / JST）
REPORT_TIME=12:00


# ─────────────────────────────────────────────
# チャンネル設定（CHANNEL_N_* の形式で複数追加可能）
# ─────────────────────────────────────────────

# チャンネル 1
CHANNEL_1_YT_HANDLE=marketing-zamurai
# 送信先 LINE グループ ID（カンマ区切りで複数グループに同時送信できます）
CHANNEL_1_LINE_GROUP_IDS=YOUR_LINE_GROUP_ID_1

# チャンネル 2
CHANNEL_2_YT_HANDLE=kusunoki3939y
# 別の LINE グループ（または複数グループ: Cxxx,Cyyy）
CHANNEL_2_LINE_GROUP_IDS=YOUR_LINE_GROUP_ID_2

# チャンネル 3 以降も同じ形式で追加できます:
# CHANNEL_3_YT_HANDLE=another_channel
# CHANNEL_3_LINE_GROUP_IDS=Caaa,Cbbb,Cccc


# ─────────────────────────────────────────────
# 複数グループへの同時送信例
# ─────────────────────────────────────────────
# CHANNEL_1_LINE_GROUP_IDS=Cabc123,Cdef456,Cghi789
# → チャンネル 1 のレポートが 3 つの LINE グループに同時送信されます
